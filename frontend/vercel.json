{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/pages/index.html"
    },
    {
      "source": "/login",
      "destination": "/pages/index.html"
    },
    {
      "source": "/register",
      "destination": "/pages/register.html"
    },
    {
      "source": "/dashboard",
      "destination": "/pages/dashboard.html"
    },
    {
      "source": "/medicines",
      "destination": "/pages/medicines.html"
    },
    {
      "source": "/history",
      "destination": "/pages/history.html"
    },
    {
      "source": "/profile",
      "destination": "/pages/profile.html"
    }
  ]
}
