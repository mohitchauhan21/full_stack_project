{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/register",
      "destination": "/register.html"
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/medicines",
      "destination": "/medicines.html"
    },
    {
      "source": "/history",
      "destination": "/history.html"
    },
    {
      "source": "/profile",
      "destination": "/profile.html"
    }
  ]
}
